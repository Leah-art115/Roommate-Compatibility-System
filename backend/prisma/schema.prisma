generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  USER
}

enum OrganizationType {
  SCHOOL
  HOSTEL
  CAMP
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum BookingStatus {
  NOT_STARTED
  QUIZ_DONE
  ALLOCATED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
}

enum SwitchRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintCategory {
  ROOMMATE_BEHAVIOR
  ROOM_CONDITION
  NOISE
  OTHER
}

enum ComplaintStatus {
  OPEN
  RESOLVED
}

model Organization {
  id        String           @id @default(uuid())
  name      String
  type      OrganizationType
  createdAt DateTime         @default(now())

  users     User[]
  invites   Invite[]
  questions Question[]
  rooms     Room[]
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  password       String
  gender         String?
  role           Role          @default(USER)
  bookingStatus  BookingStatus @default(NOT_STARTED)
  switchCount    Int           @default(0)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())

  answers         Answer[]
  questionWeights QuestionWeight[]
  roomAllocation  RoomAllocation?
  switchRequests  RoomSwitchRequest[]
  complaints      Complaint[]
}

model Invite {
  id             String       @id @default(uuid())
  name           String
  email          String
  gender         String?
  token          String       @unique
  status         InviteStatus @default(PENDING)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
}

model Question {
  id             String       @id @default(uuid())
  text           String
  type           QuestionType
  options        String[]
  scaleMin       String?
  scaleMax       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  order          Int          @default(0)
  createdAt      DateTime     @default(now())

  answers         Answer[]
  questionWeights QuestionWeight[]
}

model Answer {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  answer     String
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model QuestionWeight {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  weight     Int      // 1=Not important, 2=Somewhat, 3=Important, 4=Very Important
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model Room {
  id             String       @id @default(uuid())
  roomNumber     String
  block          String?
  capacity       Int          @default(4)
  gender         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  allocations    RoomAllocation[]
  switchRequests RoomSwitchRequest[]
}

model RoomAllocation {
  id        String   @id @default(uuid())
  userId    String   @unique
  roomId    String
  user      User     @relation(fields: [userId], references: [id])
  room      Room     @relation(fields: [roomId], references: [id])
  createdAt DateTime @default(now())
}

model RoomSwitchRequest {
  id              String              @id @default(uuid())
  userId          String
  fromRoomId      String
  reason          String
  status          SwitchRequestStatus @default(PENDING)
  rejectionReason String?
  user            User                @relation(fields: [userId], references: [id])
  fromRoom        Room                @relation(fields: [fromRoomId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Complaint {
  id          String            @id @default(uuid())
  userId      String
  category    ComplaintCategory
  description String
  status      ComplaintStatus   @default(OPEN)
  user        User              @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}
