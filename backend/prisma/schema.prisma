generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  USER
}

enum OrganizationType {
  SCHOOL
  HOSTEL
  CAMP
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Organization {
  id        String           @id @default(uuid())
  name      String
  type      OrganizationType
  createdAt DateTime         @default(now())

  users     User[]
  invites   Invite[]
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  password       String
  gender         String?
  role           Role          @default(USER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
}

model Invite {
  id             String       @id @default(uuid())
  name           String                // ← added
  email          String
  gender         String?               // ← added
  token          String       @unique
  status         InviteStatus @default(PENDING)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
}